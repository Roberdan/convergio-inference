# ============================================
# convergio-inference — Environment Variables
# ============================================

# --- AI Providers ---
# Anthropic API token for Claude models
# CONVERGIO_ANTHROPIC_TOKEN=sk-ant-your-token-here

# OpenAI API token
# CONVERGIO_OPENAI_TOKEN=sk-your-openai-token-here

# --- Model Configuration ---
# Path to models configuration file
# CONVERGIO_MODELS_CONFIG=/path/to/models.toml

# Enable MLX turbo quantization (true/false)
# CONVERGIO_MLX_TURBOQUANT=false

# --- Runtime ---
# Path to Python binary for MLX inference
# CONVERGIO_PYTHON=python3
